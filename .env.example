DATABASE_URL=postgresql://postgres:postgres@localhost:5432/grace_high_school
# Production: any standard Postgres URL works (Render, Neon, Supabase, etc.)
# Render example (auto-set when you link a Render Postgres instance):
# DATABASE_URL=postgresql://user:pass@dpg-xxxxx-a/dbname
# Set both so login always works. On boot the API creates/updates this admin.
# On Render: Dashboard → Environment → ADMIN_USERNAME / ADMIN_PASSWORD, then restart.
# Leave blank only if you prefer first-run setup at /dashboard/.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=GraceAdmin123
# Object storage: leave PRIVATE_OBJECT_DIR unset to store uploads in Postgres
# (survives Render restarts). Optional disk cache: LOCAL_UPLOAD_DIR=.local/uploads
# On Replit/GCS, set:
# PRIVATE_OBJECT_DIR=/replit-objstore-.../private
# PUBLIC_OBJECT_SEARCH_PATHS=/replit-objstore-.../public
SESSION_SECRET=local-dev-session-secret
PASSWORD_RESET_SECRET=change-me-recovery-code
NODE_ENV=development
# API server port (used when API_PROXY_TARGET points at local api-server)
PORT=8080
# Where local `pnpm dev:admin` sends /api (and SSE /api/events).
# Default (when unset): live Render site so dashboard saves update the public site in real time.
# For fully local work against `pnpm dev:api`, set:
# API_PROXY_TARGET=http://localhost:8080
API_PROXY_TARGET=https://grace-high-school-gayaza-t7p6.onrender.com
